# ZanziPay Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Server
ZANZIPAY_GRPC_PORT=50053
ZANZIPAY_REST_PORT=8090
ZANZIPAY_METRICS_PORT=9090

# Storage
ZANZIPAY_STORAGE_ENGINE=memory   # postgres | cockroach | memory
ZANZIPAY_POSTGRES_DSN=postgres://zanzipay:password@localhost:5432/zanzipay?sslmode=disable

# Security
ZANZIPAY_HMAC_KEY=changeme-super-secret-hmac-key-at-least-32-bytes

# API Authentication
ZANZIPAY_API_KEY=your-api-key-here

# Compliance
ZANZIPAY_SANCTIONS_API_KEY=

# Benchmarking (competitor endpoints)
SPICEDB_ADDR=localhost:50051
SPICEDB_PRESHARED_KEY=bench_token
OPENFGA_ADDR=http://localhost:8080
ORY_KETO_ADMIN_ADDR=http://localhost:4467
ORY_KETO_READ_ADDR=http://localhost:4466
